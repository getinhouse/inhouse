# Inhouse server configuration. Copy to server/.env and edit.
# Every value can also be set as an environment variable.
#
# Comments stay on their own lines: python-dotenv treats an inline comment
# after an EMPTY value as the value itself (so `KEY=   # note` would set
# KEY to "# note"). Keep it that way when you edit.

# ---- network / security ----------------------------------------------------
# Bind loopback or a tailnet IP; never 0.0.0.0.
INHOUSE_HOST=127.0.0.1
INHOUSE_PORT=8770
# Set to require "Authorization: Bearer <token>" on every /api request.
INHOUSE_API_TOKEN=

# ---- speech to text --------------------------------------------------------
# faster_whisper (local) | openai_compat (hosted)
INHOUSE_STT__PROVIDER=faster_whisper
# Local whisper size: tiny/base/small...
INHOUSE_STT__MODEL=base
# For a hosted endpoint instead:
#INHOUSE_STT__PROVIDER=openai_compat
#INHOUSE_STT__BASE_URL=https://api.openai.com/v1
#INHOUSE_STT__API_KEY=sk-...
#INHOUSE_STT__API_MODEL=whisper-1

# ---- language model --------------------------------------------------------
# openai_compat | anthropic
INHOUSE_LLM__PROVIDER=openai_compat
# openai_compat works with Ollama, OpenAI, vLLM, LM Studio, Groq, OpenRouter:
INHOUSE_LLM__BASE_URL=http://127.0.0.1:11434/v1
INHOUSE_LLM__API_KEY=
INHOUSE_LLM__MODEL=llama3.2
# Anthropic (native Messages API, needs: pip install 'inhouse-server[anthropic]'):
#INHOUSE_LLM__PROVIDER=anthropic
#INHOUSE_LLM__MODEL=claude-opus-4-8
#ANTHROPIC_API_KEY=sk-ant-...

# ---- text to speech --------------------------------------------------------
# piper (local) | openai_compat (hosted)
INHOUSE_TTS__PROVIDER=piper
INHOUSE_TTS__VOICE_PATH=../voices/en_US-lessac-medium.onnx
INHOUSE_TTS__SAMPLE_RATE=22050
# Hosted TTS instead:
#INHOUSE_TTS__PROVIDER=openai_compat
#INHOUSE_TTS__BASE_URL=https://api.openai.com/v1
#INHOUSE_TTS__API_KEY=sk-...
#INHOUSE_TTS__SAMPLE_RATE=24000
